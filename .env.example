# Environment variable template
# Copy this file to .env and fill in values as needed.
# The .env file is gitignored and must never be committed.

# HuggingFace token (optional - only needed for gated models)
HUGGINGFACE_TOKEN=

# AWS region for S3 access (PMC bucket is public; no credentials needed)AWS_DEFAULT_REGION=us-east-1

# Path overrides (optional - defaults are relative paths inside the repo)
# DATA_DIR=./data
# OUTPUTS_DIR=./outputs
